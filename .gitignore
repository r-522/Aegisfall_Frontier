# Godot 4 .gitignore

# Godot-specific ignores
.godot/
*.translation
export.cfg
export_credentials.cfg

# Imported translations (automatically generated from CSV files)
*.import

# Avoid ignoring Godot-generated files
!.gitkeep

# OS-specific files
.DS_Store
Thumbs.db
desktop.ini

# Editor-specific files
.idea/
.vscode/
*.suo
*.user

# Build outputs
build/
dist/
*.x86_64
*.x86
*.arm64
*.arm32
*.pck
*.apk
*.aab
*.exe

# Web export goes to web/game/ — allow it through despite *.pck rule above
!web/game/**

# Logs
*.log

# Environment
.env
.env.local
