[layer_names]

3d_physics/layer_1="World"
3d_physics/layer_2="Players"
3d_physics/layer_3="Enemies"
3d_physics/layer_4="Towers"
3d_physics/layer_5="Projectiles"
3d_physics/layer_6="Hitboxes"
3d_physics/layer_7="DetectionZones"

[physics]

3d/default_gravity=9.8
3d/default_gravity_vector=Vector3(0, -1, 0)

[debug]

gdscript/warnings/treat_warnings_as_errors=false
gdscript/warnings/inferred_declaration=0
gdscript/warnings/return_value_discarded=0
gdscript/warnings/unsafe_void_return=0
gdscript/warnings/unsafe_call_argument=0
gdscript/warnings/unsafe_cast=0
gdscript/warnings/unsafe_property_access=0
gdscript/warnings/unsafe_method_access=0

[rendering]

renderer/rendering_method="forward_plus"
renderer/rendering_method.mobile="mobile"
environment/defaults/default_clear_color=Color(0.02, 0.02, 0.04, 1)
lights_and_shadows/directional_shadow/size=4096
global_illumination/sdfgi/enabled=true
anti_aliasing/quality/msaa_3d=2
